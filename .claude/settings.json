{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel) && bash \"$ROOT/workflow/scripts/session-start.sh\"'"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel) && bash \"$ROOT/workflow/scripts/session-export.sh\"'"
          }
        ]
      }
    ]
  }
}
